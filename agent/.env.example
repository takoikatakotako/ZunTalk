# Vertex AI を呼ぶ Google Cloud プロジェクトID（必須）
GCP_PROJECT_ID=your-gcp-project-id

# 接続する Firestore データベースID（dev/prod 分離用）。未設定なら (default)。
# dev は (default)、prod は専用DB（例: zuntalk-prod）を指す。
FIRESTORE_DATABASE=(default)

# Vertex AI のリージョン（例: us-central1, asia-northeast1）
VERTEX_LOCATION=us-central1

# 使用する Gemini モデル
GEMINI_MODEL=gemini-2.5-flash

# HTTP ポート（Cloud Run では自動で注入される）
PORT=8080

# /agent を保護する共有シークレット（X-Api-Key ヘッダーと照合）。
# 空ならローカル開発用に検証スキップ。本番は Secret Manager から注入。
AGENT_API_KEY=

# deviceId ごとの /agent 日次呼び出し上限（1巡目のみカウント）。0以下で無制限。
AGENT_DAILY_LIMIT=50

# --- 電話予約（VoIP push）関連 ---

# APNs Auth Key (.p8) の Key ID（Apple Developer > Keys）
APNS_KEY_ID=

# Apple Developer の Team ID
APNS_TEAM_ID=5RH346BQ66

# .p8 ファイルの中身（PEM）。本番は Secret Manager から注入。
# 未設定なら /internal/dispatch は 503 を返す（他の API は動く）。
APNS_AUTH_KEY=

# /internal/dispatch の呼び出しを許可する Cloud Scheduler の SA email。
# 空なら OIDC 検証スキップ（ローカル開発用）。
SCHEDULER_SERVICE_ACCOUNT=

# Scheduler の OIDC トークンの audience（Terraform の dispatch_audience と一致させる）
DISPATCH_AUDIENCE=
